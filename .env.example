# ==============================================================================
# RAG Multimodal de Histología con Qdrant — Variables de Entorno
# ==============================================================================
# Copiar este archivo a .env y completar con tus claves:
#   cp .env.example .env
# ==============================================================================

# ── Google Gemini (REQUERIDO) ────────────────────────────────────────────────
# Usado para: embeddings de texto (3072d) + análisis visual de imágenes
# Obtener en: https://aistudio.google.com/apikey
GOOGLE_API_KEY=tu-api-key-de-gemini

# ── Groq (REQUERIDO) ─────────────────────────────────────────────────────────
# Usado para: LLM principal (Llama 4 Scout) — chat, clasificación, entidades
# Obtener en: https://console.groq.com/keys
GROQ_API_KEY=tu-api-key-de-groq

# ── Qdrant Cloud (REQUERIDO) ─────────────────────────────────────────────────
# Usado para: base de datos vectorial (chunks + imágenes + memoria)
# Obtener en: https://cloud.qdrant.io/ → crear cluster gratuito
QDRANT_URL=https://tu-cluster.region.gcp.cloud.qdrant.io:6333
QDRANT_KEY=tu-api-key-de-qdrant

# ── Hugging Face (REQUERIDO) ─────────────────────────────────────────────────
# Usado para: descargar modelos UNI (MahmoodLab) y PLIP (vinid)
# Obtener en: https://huggingface.co/settings/tokens
# NOTA: Tu token necesita acceso a MahmoodLab/uni (solicitar en HF)
HF_TOKEN=tu-token-de-huggingface

# ── LangSmith (OPCIONAL) ─────────────────────────────────────────────────────
# Usado para: observabilidad y trazas del pipeline RAG
# Obtener en: https://smith.langchain.com/
LANGSMITH_API_KEY=tu-api-key-de-langsmith
